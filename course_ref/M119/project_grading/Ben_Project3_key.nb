Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mu", " ", "=", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"x", "/", 
       RowBox[{"(", 
        RowBox[{"b", "-", "a"}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"var", " ", "=", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "-", 
         FractionBox[
          RowBox[{"a", "+", "b"}], "2"]}], ")"}], "^", "2"}], "*", 
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"b", "-", "a"}], ")"}]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"Assuming", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"xbar", ">", "0"}], ",", 
       RowBox[{"varbar", ">", "0"}], ",", 
       RowBox[{"a", ">", "b"}]}], "}"}], ",", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"mu", "\[Equal]", "xbar"}], " ", "&&", " ", 
        RowBox[{"var", "\[Equal]", "varbar"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"a", ",", "b"}], "}"}]}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"params", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"xbar", "\[Rule]", "sampleMean"}], ",", 
     RowBox[{"varbar", "\[Rule]", "sampleVar"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"gunif1", "=", 
  RowBox[{"Grid", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<mu\>\"", ",", "mu"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<variance\>\"", ",", "var"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<parameters\>\"", ",", "params"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<parameters evaluated\>\"", ",", 
        RowBox[{"params", "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"xbar", "\[Rule]", "sampleMean"}], ",", 
           RowBox[{"varbar", "\[Rule]", "sampleVar"}]}], "}"}]}]}], "}"}]}], 
     "}"}], ",", 
    RowBox[{"Frame", "\[Rule]", "All"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.8345667461686974`*^9, 3.83456675120988*^9}, {
