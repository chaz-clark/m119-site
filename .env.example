# Canvas course ID — visible in the Canvas course URL: /courses/XXXXXX
CANVAS_COURSE_ID=

# Canvas API token — generate at: Canvas → Account → Settings → New Access Token
# Requires instructor or admin role on the course
CANVAS_API_TOKEN=

# Canvas instance URL — no trailing slash
# Examples: https://byui.instructure.com  |  https://canvas.instructure.com
CANVAS_BASE_URL=

# Optional: master template course and Canvas Blueprint course (for three-course architecture)
# See README.md for details. Required only if using course_mirror.py or blueprint_sync.py.
MASTER_COURSE_ID=
BLUEPRINT_COURSE_ID=

# Optional: sandbox course for QC testing before sprint commits (safe to read/write)
CANVAS_SANDBOX_ID=
